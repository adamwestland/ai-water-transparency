---
import type { DisclosureStatus } from '../lib/providers';

interface Props {
  status: DisclosureStatus;
}

const { status } = Astro.props;

const labels: Record<DisclosureStatus, string> = {
  yes: 'Yes',
  no: 'No',
  partial: 'Partial',
};

const classes: Record<DisclosureStatus, string> = {
  yes: 'text-badge-yes-text font-semibold',
  no: 'text-badge-no-text font-normal',
  partial: 'text-badge-partial-text font-medium',
};
---

<span class={`text-sm ${classes[status]}`}>
  {labels[status]}
</span>
