---
import DisclosureBadge from './DisclosureBadge.astro';
import { DISCLOSURE_LABELS, DISCLOSURE_ORDER } from '../lib/disclosure-labels';
import type { Provider } from '../lib/providers';

interface Props {
  providers: Provider[];
}

const { providers } = Astro.props;

const barColor = {
  yes: 'border-badge-yes-text',
  no: 'border-badge-no-text',
  partial: 'border-badge-partial-text',
};

const colCount = DISCLOSURE_ORDER.length + 1;
---

<div class="overflow-x-auto">
  <table class="w-full text-sm font-body border-collapse">
    <thead>
      <tr class="border-b border-border-subtle">
        <th class="text-left text-xs font-medium text-text-faint uppercase tracking-wider py-3 pr-4">Provider</th>
        {DISCLOSURE_ORDER.map((key) => (
          <th class="text-center text-xs font-medium text-text-faint uppercase tracking-wider py-3 px-3">
            {DISCLOSURE_LABELS[key]}
          </th>
        ))}
      </tr>
    </thead>
    <tbody>
      {providers.map((provider) => (
        <>
          <tr
            class="cursor-pointer provider-row"
            data-provider={provider.id}
          >
            <td class="py-3 pr-4 border-b-4 border-transparent">
              <span class="font-semibold text-text-primary">{provider.name}</span>
            </td>
            {DISCLOSURE_ORDER.map((key) => {
              const disclosure = provider.disclosures[key];
              if (!disclosure) return <td class="px-3 py-3 border-b-4 border-transparent" />;
              return (
                <td class={`px-3 py-3 text-center border-b-4 ${barColor[disclosure.status] || 'border-transparent'}`}>
                  <DisclosureBadge status={disclosure.status} />
                </td>
              );
            })}
          </tr>
          <tr class="provider-detail hidden" data-provider-detail={provider.id}>
            <td colspan={colCount} class="px-4 py-4 bg-bg-card border-b border-border-subtle">
              <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4 text-xs text-text-muted leading-relaxed">
                {DISCLOSURE_ORDER.map((key) => {
                  const disclosure = provider.disclosures[key];
                  if (!disclosure) return null;
                  return (
                    <div>
                      <p class="font-medium text-text-primary mb-1">{DISCLOSURE_LABELS[key]}</p>
                      <p>{disclosure.detail}</p>
                      {disclosure.source_url ? (
                        <a
                          href={disclosure.source_url}
                          class="underline hover:text-text-primary mt-1 inline-block"
                          style="color: #2d6a9f;"
                          target="_blank"
                          rel="noopener"
                        >
                          View source &rarr;
                        </a>
                      ) : (
                        <p class="text-text-faint mt-1">
                          Checked {provider.last_updated}
                        </p>
                      )}
                    </div>
                  );
                })}
              </div>
            </td>
          </tr>
        </>
      ))}
    </tbody>
  </table>
</div>

<script>
  document.querySelectorAll('.provider-row').forEach((row) => {
    row.addEventListener('click', () => {
      const id = row.getAttribute('data-provider');
      const detail = document.querySelector(`.provider-detail[data-provider-detail="${id}"]`);
      if (detail) {
        detail.classList.toggle('hidden');
      }
    });
  });
</script>
