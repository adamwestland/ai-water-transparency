---
import DisclosureBadge from './DisclosureBadge.astro';
import { DISCLOSURE_LABELS, DISCLOSURE_ORDER } from '../lib/disclosure-labels';
import type { Provider } from '../lib/providers';

interface Props {
  providers: Provider[];
}

const { providers } = Astro.props;
---

<div class="overflow-x-auto">
  <table class="w-full text-sm font-body border-collapse">
    <thead>
      <tr class="border-b border-border-subtle">
        <th class="text-left text-xs font-medium text-text-faint uppercase tracking-wider py-3 pr-4">Provider</th>
        {DISCLOSURE_ORDER.map((key) => (
          <th class="text-left text-xs font-medium text-text-faint uppercase tracking-wider py-3 px-3">
            {DISCLOSURE_LABELS[key]}
          </th>
        ))}
      </tr>
    </thead>
    <tbody>
      {providers.map((provider, i) => (
        <tr class={`border-b border-border-subtle ${i % 2 === 1 ? 'bg-bg-warm/50' : ''}`}>
          <td class="py-3 pr-4">
            <span class="font-semibold text-text-primary">{provider.name}</span>
          </td>
          {DISCLOSURE_ORDER.map((key) => {
            const disclosure = provider.disclosures[key];
            if (!disclosure) return <td class="px-3 py-3" />;
            return (
              <td class="px-3 py-3">
                <details>
                  <summary class="cursor-pointer list-none [&::-webkit-details-marker]:hidden">
                    <DisclosureBadge status={disclosure.status} />
                  </summary>
                  <div class="mt-2 text-xs text-text-muted leading-relaxed max-w-48">
                    <p>{disclosure.detail}</p>
                    {disclosure.source_url ? (
                      <a
                        href={disclosure.source_url}
                        class="underline hover:text-text-primary mt-1 inline-block"
                        style="color: #2d6a9f;"
                        target="_blank"
                        rel="noopener"
                      >
                        View source &rarr;
                      </a>
                    ) : (
                      <p class="text-text-faint mt-1">
                        Checked {provider.last_updated}
                      </p>
                    )}
                  </div>
                </details>
              </td>
            );
          })}
        </tr>
      ))}
    </tbody>
  </table>
</div>
